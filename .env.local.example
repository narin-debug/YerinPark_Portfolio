# 이 파일을 복사해 .env.local 로 만들고 실제 값을 채우세요.
# .env.local 은 .gitignore에 포함되어 있어 git에 커밋되지 않습니다.

# Supabase 프로젝트 → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# node scripts/hash-password.mjs "원하는 비밀번호" 실행 결과를 붙여넣기
ADMIN_PASSWORD_HASH=

# 세션 쿠키 서명용 임의의 긴 문자열 (예: node -e "console.log(crypto.randomUUID()+crypto.randomUUID())")
SESSION_SECRET=
